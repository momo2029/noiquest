FROM node:18-alpine

WORKDIR /app

# 安装构建依赖和 OpenSSL
RUN apk add --no-cache python3 make g++ openssl

# 复制 package 文件
COPY package*.json ./

# 安装所有依赖（包括 devDependencies 用于构建）
RUN npm ci

# 复制 Prisma schema
COPY prisma ./prisma/

# 生成 Prisma Client
RUN npx prisma generate

# 复制源代码
COPY . .

# 暴露端口
EXPOSE 3001

# 启动命令（使用 tsx 直接运行）
CMD ["sh", "-c", "npx prisma migrate deploy && npx tsx prisma/seed.ts && npx tsx src/index.ts"]
