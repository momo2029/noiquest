{
  "name": "noi-quest-server",
  "version": "1.0.0",
  "description": "NOI Quest 后端服务",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv -e .env.development -- npx tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -e .env.production -- node dist/index.js",
    "db:generate": "dotenv -e .env.development -- prisma generate",
    "db:push": "dotenv -e .env.development -- prisma db push",
    "db:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "db:seed": "dotenv -e .env.development -- npx tsx prisma/seed.ts",
    "db:push:prod": "dotenv -e .env.production -- prisma db push",
    "db:seed:prod": "dotenv -e .env.production -- npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@types/nodemailer": "^7.0.5",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.12",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
