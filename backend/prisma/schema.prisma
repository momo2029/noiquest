generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户角色枚举
enum Role {
  STUDENT
  TEACHER
  ADMIN
}

// 难度枚举
enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// 题目类型枚举
enum QuestionType {
  CODING          // 编程题（现有）
  FILL_BLANK      // 代码填空题
  CODE_ORDER      // 代码排序题
  MULTIPLE_CHOICE // 选择题
  MATCHING        // 配对题
  BUG_FIX         // 改错题
}

// 每日目标等级枚举
enum DailyGoalLevel {
  CASUAL     // 10 XP
  REGULAR    // 20 XP
  SERIOUS    // 30 XP
  INTENSE    // 50 XP
}

// 错题状态枚举
enum MistakeStatus {
  UNREVIEWED   // 未复习
  REVIEWING    // 复习中
  MASTERED     // 已掌握
}

// 用户表
model User {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  password      String
  name          String
  avatar        String   @default("🦊")
  role          Role     @default(STUDENT)

  // 游戏化数据
  level         Int      @default(1)
  xp            Int      @default(0)
  totalXp       Int      @default(0)
  streak        Int      @default(0)
  lastStudyDate DateTime?
  streakProtectedAt DateTime?              // 上次使用 Streak 保护的时间
  hearts        Int      @default(5)
  maxHearts     Int      @default(5)           // 最大生命值
  heartsUpdatedAt DateTime @default(now())     // 心的更新时间（用于计算恢复）
  gems          Int      @default(0)

  // 邀请码
  inviteCode    String?  // 用户使用的邀请码

  // 班级信息
  classId       String?
  class         Class?   @relation(fields: [classId], references: [id])

  // 关联
  progress      ExerciseProgress[]
  achievements  UserAchievement[]
  submissions   Submission[]
  assignedHomework StudentHomework[]
  chatMessages  ChatMessage[]
  aiUsageRecords AIUsageRecord[]

  // 教师创建的作业
  createdHomework Homework[] @relation("TeacherHomework")

  // 多邻国模式关联
  unitProgress    UserUnitProgress[]
  lessonProgress  UserLessonProgress[]
  dailySettings   UserDailySettings?
  dailyQuests     UserDailyQuest[]
  dailyXpRecords  DailyXpRecord[]
  knowledgeMastery KnowledgeMastery[]
  mistakeRecords  MistakeRecord[]

  // 排行榜与联赛
  leaderboardEntries LeaderboardEntry[]
  league             UserLeague?

  // 学习分析
  learningSessions   LearningSession[]
  dailyLearningStats DailyLearningStats[]

  // 复习提醒
  reviewReminders    ReviewReminder[]

  // 兑换记录
  redeemRecords      RedeemRecord[]

  // 单设备登录控制
  tokenVersion  Int      @default(0)

  // 用户文件
  files         UserFile[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([classId])
  @@index([role])
  @@index([username])
  @@index([inviteCode])
}

// 班级表
model Class {
  id          String   @id @default(uuid())
  name        String
  description String?
  teacherId   String

  students    User[]
  homework    Homework[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teacherId])
}

// 练习题表
model Exercise {
  id          String       @id @default(uuid())
  title       String
  description String
  difficulty  Difficulty
  category    String
  starterCode String
  hint        String?
  solution    String?
  xp          Int          @default(10)
  orderIndex  Int          @default(0)
  isPublished Boolean      @default(true)

  // 多邻国模式新增字段
  type         QuestionType @default(CODING)
  questionData Json?        // 存储不同题型的具体数据

  // 题目来源区分
  source       String       @default("SKILL_TREE")  // SKILL_TREE | EXERCISE_LIBRARY

  // 技能树关联（仅 source=SKILL_TREE 时有值）
  unitId       String?
  lessonId     String?

  // 关联
  progress    ExerciseProgress[]
  submissions Submission[]
  homeworkExercises HomeworkExercise[]
  unit        SkillUnit?   @relation(fields: [unitId], references: [id])
  lesson      Lesson?      @relation(fields: [lessonId], references: [id])
  mistakeRecords MistakeRecord[]
  knowledgePoints ExerciseKnowledgePoint[]
  statistics  ExerciseStatistics?
  testCases   TestCase[]   // 测试用例（练习题库编程题）

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([category])
  @@index([difficulty])
  @@index([unitId])
  @@index([lessonId])
  @@index([type])
  @@index([isPublished])
  @@index([source])
}

// 练习进度表
model ExerciseProgress {
  id             String   @id @default(uuid())
  userId         String
  exerciseId     String
  completed      Boolean  @default(false)
  code           String?
  completedAt    DateTime?
  completedCount Int      @default(0)   // 完成次数（区分首次/重做）
  xpEarned       Int      @default(0)   // 累计获得XP

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([exerciseId])
}

// 代码提交记录
model Submission {
  id          String   @id @default(uuid())
  userId      String
  exerciseId  String
  code        String
  status      String   @default("pending") // pending, success, error
  output      String?
  errorMsg    String?
  executionTime Int?   // 毫秒

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([exerciseId])
  @@index([createdAt])
}

// 成就表
model Achievement {
  id          String   @id @default(uuid())
  key         String   @unique                   // 成就标识符
  name        String                             // 成就名称
  description String                             // 成就描述
  icon        String                             // 图标
  category    String   @default("MILESTONE")     // MILESTONE/STREAK/MASTERY/PERFECT/SPEED/COLLECTION
  condition   Json     @default("{}")            // 解锁条件 { "type": "lessonsCompleted", "value": 10 }
  reward      Json     @default("{\"xp\": 0, \"gems\": 0}")  // 奖励 { "xp": 50, "gems": 20 }
  rarity      String   @default("COMMON")        // COMMON/RARE/EPIC/LEGENDARY
  orderIndex  Int      @default(0)

  users       UserAchievement[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([category])
  @@index([rarity])
}

// 用户成就关联表
model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())
  progress      Int      @default(0)         // 当前进度（用于显示进度条）
  notified      Boolean  @default(false)     // 是否已通知用户

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([notified])
}

// 作业表
model Homework {
  id          String   @id @default(uuid())
  title       String
  description String?
  classId     String
  teacherId   String
  dueDate     DateTime?

  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher     User     @relation("TeacherHomework", fields: [teacherId], references: [id])
  exercises   HomeworkExercise[]
  students    StudentHomework[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([classId])
  @@index([teacherId])
}

// 作业-练习关联表
model HomeworkExercise {
  id          String   @id @default(uuid())
  homeworkId  String
  exerciseId  String
  orderIndex  Int      @default(0)

  homework    Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([homeworkId, exerciseId])
}

// 学生作业状态表
model StudentHomework {
  id          String   @id @default(uuid())
  studentId   String
  homeworkId  String
  status      String   @default("pending") // pending, in_progress, completed
  submittedAt DateTime?
  score       Int?
  feedback    String?

  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  homework    Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)

  @@unique([studentId, homeworkId])
  @@index([studentId])
  @@index([homeworkId])
}

// AI 聊天消息表
model ChatMessage {
  id          String   @id @default(uuid())
  userId      String
  sessionId   String
  role        String   // user, assistant
  content     String

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}

// 验证码表
model VerificationCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@index([used])
}

// 系统配置表
model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String

  updatedAt DateTime @updatedAt
}

// ==================== 多邻国模式新增模型 ====================

// 技能单元
model SkillUnit {
  id             String   @id @default(uuid())
  title          String
  description    String
  icon           String   @default("📚")
  color          String   @default("from-blue-400 to-blue-600")
  orderIndex     Int      @default(0)
  requiredXp     Int      @default(0)
  prerequisiteId String?
  isPublished    Boolean  @default(true)

  prerequisite   SkillUnit?  @relation("UnitPrerequisite", fields: [prerequisiteId], references: [id])
  dependents     SkillUnit[] @relation("UnitPrerequisite")
  lessons        Lesson[]
  exercises      Exercise[]
  userProgress   UserUnitProgress[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orderIndex])
  @@index([prerequisiteId])
  @@index([isPublished])
}

// 课程
model Lesson {
  id           String     @id @default(uuid())
  title        String
  description  String?
  orderIndex   Int        @default(0)
  unitId       String
  isPublished  Boolean    @default(true)

  unit         SkillUnit  @relation(fields: [unitId], references: [id], onDelete: Cascade)
  exercises    Exercise[]
  userProgress UserLessonProgress[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([unitId])
  @@index([orderIndex])
  @@index([isPublished])
}

// 用户单元进度
model UserUnitProgress {
  id               String    @id @default(uuid())
  userId           String
  unitId           String
  unlocked         Boolean   @default(false)
  completed        Boolean   @default(false)
  lessonsCompleted Int       @default(0)
  crownLevel       Int       @default(0)  // 0-3 皇冠等级
  perfectCount     Int       @default(0)  // 完美通关次数

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit   SkillUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, unitId])
  @@index([userId])
  @@index([unitId])
}

// 用户课程进度
model UserLessonProgress {
  id              String    @id @default(uuid())
  userId          String
  lessonId        String
  completed       Boolean   @default(false)
  mistakes        Int       @default(0)
  perfectRun      Boolean   @default(false)
  completedCount  Int       @default(0)   // 完成次数（区分首次/重做）
  xpEarned        Int       @default(0)   // 累计获得XP
  lastCompletedAt DateTime?               // 最后完成时间

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

// 用户每日设置
model UserDailySettings {
  id              String         @id @default(uuid())
  userId          String         @unique
  dailyGoal       DailyGoalLevel @default(REGULAR)
  reminderEnabled Boolean        @default(true)
  reminderTime    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 每日任务模板
model DailyQuestTemplate {
  id          String  @id @default(uuid())
  title       String
  description String
  questType   String  // complete_exercises, study_minutes, perfect_lessons
  targetValue Int
  xpReward    Int     @default(10)
  gemsReward  Int     @default(0)
  active      Boolean @default(true)

  instances UserDailyQuest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 用户每日任务
model UserDailyQuest {
  id           String   @id @default(uuid())
  userId       String
  templateId   String
  currentValue Int      @default(0)
  targetValue  Int
  completed    Boolean  @default(false)
  claimed      Boolean  @default(false)
  xpReward     Int
  gemsReward   Int      @default(0)
  date         DateTime @db.Date

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  template DailyQuestTemplate @relation(fields: [templateId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, templateId, date])
  @@index([userId])
  @@index([date])
}

// 每日 XP 记录
model DailyXpRecord {
  id       String   @id @default(uuid())
  userId   String
  date     DateTime @db.Date
  xpEarned Int      @default(0)
  goalMet  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// 知识点掌握度
model KnowledgeMastery {
  id             String    @id @default(uuid())
  userId         String
  knowledgeKey   String    // category 或 unitId
  knowledgeType  String    // category, unit
  masteryLevel   Int       @default(0)  // 0-100
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  reviewCount    Int       @default(0)
  correctCount   Int       @default(0)
  incorrectCount Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, knowledgeKey])
  @@index([userId])
  @@index([nextReviewAt])
}

// 错题本
model MistakeRecord {
  id            String        @id @default(uuid())
  userId        String
  exerciseId    String
  lessonId      String?                            // 所属课程
  unitId        String?                            // 所属单元
  source        String        @default("SKILL_TREE")  // SKILL_TREE | EXERCISE_LIBRARY | REVIEW
  status        MistakeStatus @default(UNREVIEWED) // 错题状态
  wrongCount    Int           @default(1)          // 错误次数
  correctStreak Int           @default(0)          // 连续答对次数（达到2次变为MASTERED）
  userAnswer    Json?                              // 最近一次错误答案
  correctAnswer Json?                              // 正确答案
  wrongAnswers  Json?                              // 历史错误答案 [{ answer, timestamp }]
  lastWrongAt   DateTime      @default(now())      // 最后错误时间
  reviewedAt    DateTime?                          // 最后复习时间
  masteredAt    DateTime?                          // 掌握时间

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, lessonId])
  @@index([source])
}

// ==================== 邀请码系统 ====================

// 邀请码表
model InviteCode {
  id          String    @id @default(uuid())
  code        String    @unique
  createdBy   String?   // 创建者ID（管理员）
  usedBy      String?   // 使用者ID
  usedAt      DateTime?
  expiresAt   DateTime?
  maxUses     Int       @default(1)  // 最大使用次数
  usedCount   Int       @default(0)  // 已使用次数
  type        String    @default("STUDENT")  // STUDENT, TEACHER, ADMIN
  note        String?   // 备注

  createdAt   DateTime  @default(now())

  @@index([code])
  @@index([createdBy])
  @@index([type])
}

// AI 使用记录表（用于限制每日调用次数）
model AIUsageRecord {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @db.Date
  count     Int      @default(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ==================== 知识点系统 ====================

// 知识点
model KnowledgePoint {
  id          String   @id @default(uuid())
  name        String   @unique
  category    String
  orderIndex  Int      @default(0)

  exercises   ExerciseKnowledgePoint[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

// 题目-知识点关联
model ExerciseKnowledgePoint {
  id               String         @id @default(uuid())
  exerciseId       String
  knowledgePointId String

  exercise         Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, knowledgePointId])
  @@index([exerciseId])
  @@index([knowledgePointId])
}

// ==================== 排行榜与联赛系统 ====================

// 排行榜周期枚举
enum LeaderboardPeriod {
  DAILY
  WEEKLY
  MONTHLY
  ALL_TIME
}

// 联赛等级枚举
enum LeagueLevel {
  BRONZE
  SILVER
  GOLD
  DIAMOND
  MASTER
}

// 排行榜条目
model LeaderboardEntry {
  id        String            @id @default(uuid())
  userId    String
  period    LeaderboardPeriod
  periodKey String            // 2024-01-20 / 2024-W03 / 2024-01 / all
  xp        Int               @default(0)
  rank      Int?

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, period, periodKey])
  @@index([period, periodKey])
  @@index([xp(sort: Desc)])
}

// 用户联赛信息
model UserLeague {
  id          String      @id @default(uuid())
  userId      String      @unique
  league      LeagueLevel @default(BRONZE)
  weeklyXp    Int         @default(0)
  weeklyRank  Int?
  promotedAt  DateTime?
  demotedAt   DateTime?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== 学习分析系统 ====================

// 学习会话类型枚举
enum SessionType {
  LESSON
  REVIEW
  PRACTICE
}

// 学习会话记录
model LearningSession {
  id            String      @id @default(uuid())
  userId        String
  sessionType   SessionType
  startedAt     DateTime    @default(now())
  endedAt       DateTime?
  duration      Int?        // 秒
  exerciseCount Int         @default(0)
  correctCount  Int         @default(0)
  xpEarned      Int         @default(0)

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([sessionType])
}

// 每日学习统计
model DailyLearningStats {
  id               String   @id @default(uuid())
  userId           String
  date             DateTime @db.Date
  totalDuration    Int      @default(0)    // 总学习时长（秒）
  sessionsCount    Int      @default(0)    // 学习次数
  exercisesCount   Int      @default(0)    // 完成题目数
  correctCount     Int      @default(0)    // 正确数
  xpEarned         Int      @default(0)    // 获得XP
  lessonsCompleted Int      @default(0)    // 完成课程数
  reviewsCompleted Int      @default(0)    // 完成复习数

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
}

// ==================== 题目统计系统 ====================

// 题目统计
model ExerciseStatistics {
  id               String   @id @default(uuid())
  exerciseId       String   @unique
  totalAttempts    Int      @default(0)    // 总尝试次数
  correctFirst     Int      @default(0)    // 首次正确次数
  totalCorrect     Int      @default(0)    // 总正确次数
  uniqueUsers      Int      @default(0)    // 独立用户数
  totalTimeSeconds Int      @default(0)    // 总用时（秒）
  skippedCount     Int      @default(0)    // 跳过次数
  commonMistakes   Json?                   // 常见错误 [{ answer: "...", count: 10 }]

  exercise         Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  updatedAt        DateTime @updatedAt
}

// ==================== 内容版本控制 ====================

// 变更类型枚举
enum ChangeType {
  CREATE
  UPDATE
  DELETE
}

// 内容版本记录
model ContentVersion {
  id          String     @id @default(uuid())
  entityType  String     // SKILL_UNIT / LESSON / EXERCISE
  entityId    String
  version     Int
  data        Json       // 完整的实体数据快照
  changeType  ChangeType
  changedBy   String     // 操作者ID
  changeNote  String?    // 修改说明

  createdAt   DateTime   @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ==================== 复习提醒系统 ====================

// 提醒类型枚举
enum ReminderType {
  DUE_REVIEW      // 有到期复习内容
  INACTIVE        // 连续多天未学习
  MASTERY_DROP    // 知识点掌握度下降
  MISTAKES_PILE   // 错题累积超过阈值
  STREAK_RISK     // 连续学习天数有风险
}

// 复习提醒
model ReviewReminder {
  id          String       @id @default(uuid())
  userId      String
  type        ReminderType
  title       String
  message     String
  data        Json?        // 附加数据
  read        Boolean      @default(false)
  dismissed   Boolean      @default(false)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())

  @@index([userId, read])
  @@index([type])
}

// ==================== 兑换码系统 ====================

// 兑换码类型枚举
enum RedeemCodeType {
  GEMS            // 宝石
  HEARTS          // 生命值
  STREAK_PROTECT  // Streak 保护
}

// 兑换码
model RedeemCode {
  id          String         @id @default(uuid())
  code        String         @unique
  type        RedeemCodeType
  value       Int                              // 数量（宝石数/心数/天数）
  maxUses     Int            @default(1)       // 最大使用次数
  usedCount   Int            @default(0)       // 已使用次数
  expiresAt   DateTime?                        // 过期时间
  createdBy   String?                          // 创建者ID
  note        String?                          // 备注

  records     RedeemRecord[]

  createdAt   DateTime       @default(now())

  @@index([code])
  @@index([type])
}

// 兑换记录
model RedeemRecord {
  id          String     @id @default(uuid())
  userId      String
  codeId      String

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code        RedeemCode @relation(fields: [codeId], references: [id], onDelete: Cascade)

  redeemedAt  DateTime   @default(now())

  @@unique([userId, codeId])
  @@index([userId])
}

// ==================== 用户文件系统 ====================

// 用户代码文件
model UserFile {
  id        String   @id @default(uuid())
  userId    String
  name      String   // 文件名（必须以 .cpp 结尾）
  content   String   @db.Text

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([updatedAt])
}

// ==================== 练习题库测试用例 ====================

// 测试用例（练习题库编程题专用）
model TestCase {
  id          String   @id @default(uuid())
  exerciseId  String
  input       String   @db.Text    // 输入数据
  output      String   @db.Text    // 期望输出
  isHidden    Boolean  @default(false)  // 是否隐藏（防作弊）
  orderIndex  Int      @default(0)
  timeLimit   Int?     // 单独的时间限制（毫秒），null 则用默认值
  memoryLimit Int?     // 单独的内存限制（KB），null 则用默认值

  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([exerciseId])
  @@index([orderIndex])
}
